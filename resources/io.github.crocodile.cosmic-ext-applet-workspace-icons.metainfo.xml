  <name>Workspace Icons</name>
  <summary>Show application icons on COSMIC workspaces</summary>
  <description>
    <p>Workspace Icons is a COSMIC panel applet that adds application icons to numbered workspaces. It helps you see which apps are open on each workspace and monitor without opening the workspace overview.</p>
    <p>The applet keeps the familiar workspace switching, scrolling, and overview behavior from COSMIC's built-in workspace applet while adding compact visual context for open, minimized, and maximized windows.</p>
  </description>
  <launchable type="desktop-id">io.github.crocodile.cosmic-ext-applet-workspace-icons.desktop</launchable>
  <url type="homepage">https://github.com/crocodile/cosmic-ext-applet-workspace-icons</url>
  <url type="bugtracker">https://github.com/crocodile/cosmic-ext-applet-workspace-icons/issues</url>
  <url type="vcs-browser">https://github.com/crocodile/cosmic-ext-applet-workspace-icons</url>
  <provides>
    <id>com.system76.CosmicApplet</id>
    <binary>cosmic-ext-applet-workspace-icons</binary>
  </provides>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <supports>
